Console.OutputEncoding = System.Text.Encoding.UTF8;
//declaração de variáveis locais
float moeda, conversorReal, resultado;
int escolha;
Console.WriteLine("Conversor de moedas🧮");
Console.Write("Digite o valor: ");
float.TryParse(Console.ReadLine()!, out moeda);
Console.WriteLine("\nDigte 1 para converter para dólar\n" +
    "Digite 2 para converter para libras\nDigite: ");
int.TryParse(Console.ReadLine(), out escolha);
switch (escolha) {
    case 1:
        Console.Write("Digite o valor de dólar turismo: ");
        float.TryParse(Console.ReadLine()!.Replace(".",","), out conversorReal);
        resultado = moeda / conversorReal;
        Console.WriteLine($"R${moeda} / U${conversorReal} = R${resultado}");
        break;
    case 2:
        Console.Write("Digite o valor da libra turismo: ");
        float.TryParse(Console.ReadLine()!.Replace(".",","), out conversorReal);
        resultado = moeda / conversorReal;
        Console.WriteLine($"R${moeda} / £{conversorReal} = £{resultado}");
        break;
    default:
        Console.WriteLine("Opção inválida.");
        break;
}
